# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Agent ---
# Claude model that powers the agent's reasoning.
JARVIS_MODEL=claude-opus-4-8
# low | medium | high | xhigh | max
JARVIS_EFFORT=high

# --- Execution ---
# paper = simulated fills against live market prices (default, safe)
# live  = route orders to a real broker (requires Alpaca keys below)
EXECUTION_MODE=paper
# Starting cash for the paper portfolio (used on first run only).
PAPER_STARTING_CASH=100000
# If false, every order requires interactive y/n confirmation.
# The autonomous loop refuses to run live unless this is explicitly true.
AUTO_APPROVE=false

# --- Risk limits (fractions of total equity) ---
# Max value of a single order.
RISK_MAX_ORDER_PCT=0.10
# Max total exposure to one symbol after the order fills.
RISK_MAX_POSITION_PCT=0.20
# Minimum cash reserve that buys may never breach.
RISK_MIN_CASH_PCT=0.05
# Max number of orders per calendar day.
RISK_MAX_ORDERS_PER_DAY=10

# --- Paper-fill realism ---
# Slippage applied against you on simulated fills (basis points).
FILL_SLIPPAGE_BPS=5
# Flat commission charged per order (USD).
COMMISSION_PER_ORDER=0

# --- Dashboard ---
# When set, every /api request must send "Authorization: Bearer <token>".
# REQUIRED before exposing the dashboard beyond localhost.
JARVIS_DASHBOARD_TOKEN=

# --- Alerts (thresholds in percent; each rule fires max once per day) ---
# A holding is down more than X% from its average cost.
ALERT_POSITION_DRAWDOWN_PCT=15
# Total equity is down more than X% from its recorded peak.
ALERT_PORTFOLIO_DRAWDOWN_PCT=10
# Equity moved more than X% in a single day.
ALERT_DAILY_MOVE_PCT=5
# Optional: POST {"text": ...} to this URL (Slack/Discord-compatible).
ALERT_WEBHOOK_URL=
# Optional: SMTP email channel.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# --- Optional: Alpaca (only used when EXECUTION_MODE=live) ---
# Defaults to Alpaca's paper-trading endpoint even in "live" mode;
# point it at https://api.alpaca.markets only when you truly mean it.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
